# ── Model Selection (M1 Pro 16GB optimized) ───────────────────────────────────
# Primary LLM — pick one:
#   llama3.2:3b          ~2.0 GB  fast, great for testing
#   llama3.1:8b          ~4.9 GB  best quality/VRAM trade-off on 16GB (default tag is q4_K_M)
#   mistral:7b-q4_K_M    ~4.1 GB  strong reasoning, good for RAG
#   phi3.5:3.8b          ~2.2 GB  fast, strong at instruction-following
LLM_MODEL=llama3.1:8b

# Embedding model (lightweight, 768-dim)
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# ── RAG Configuration ─────────────────────────────────────────────────────────
COLLECTION_NAME=localai_docs

# RealityEngine endpoint targets. Defaults match the CI Docker public contract.
# RE is published on host :5001 (host :3000 is Grafana). PE is on host :3004.
#
# IMPORTANT — native multi-engine mode (issue #44): when the engines run
# NATIVELY (startUniverse.sh --engines=...), the Docker ports below do NOT
# exist and the api bridge will silently report `bridge: degraded` with
# re/pe unreachable. In that mode point the bridge at the native engine
# (default scala-1, http, no TLS):
#   RE_URL=http://host.docker.internal:5101
#   PE_URL=http://host.docker.internal:5100
#   RE_SSL_VERIFY=false
# startUniverse.sh stage 5 sets these automatically; only override manually
# if you start the api yourself (e.g. `docker compose up -d api`).
RE_URL=https://host.docker.internal:5001
PE_URL=https://host.docker.internal:3004
RE_SSL_VERIFY=false

# ── Security ──────────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change-me-before-use

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
