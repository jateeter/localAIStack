# ── Model Selection (M1 Pro 16GB optimized) ───────────────────────────────────
# Primary LLM — pick one:
#   llama3.2:3b          ~2.0 GB  fast, great for testing
#   llama3.1:8b          ~4.9 GB  best quality/VRAM trade-off on 16GB (default tag is q4_K_M)
#   mistral:7b-q4_K_M    ~4.1 GB  strong reasoning, good for RAG
#   phi3.5:3.8b          ~2.2 GB  fast, strong at instruction-following
LLM_MODEL=llama3.1:8b

# Embedding model — Ternary Bonsai 4 (ternary-weight compressed, ~768-dim).
# Override EMBED_DIM below if your Bonsai variant has a different output size;
# EMBED_DIM must match the vector size of the `localai_docs` Qdrant collection,
# so change it BEFORE the first ingest or recreate the collection afterwards.
#
# ⚠ KNOWN ISSUE: prism-ml ships only a Q1_0 (BitNet ternary) GGUF, which
# Ollama's bundled GGML does not yet recognize — embedding calls will 500
# (file_type=unknown) until upstream Ollama adds TQ1_0/BitNet support.
# For a working default today, use:  EMBED_MODEL=nomic-embed-text (EMBED_DIM=768)
EMBED_MODEL=ternary-bonsai:4
EMBED_DIM=768

# ── RAG Configuration ─────────────────────────────────────────────────────────
COLLECTION_NAME=localai_docs

# RealityEngine endpoint targets. Defaults match the CI Docker public contract.
RE_URL=https://host.docker.internal:3000
PE_URL=https://host.docker.internal:3004
RE_SSL_VERIFY=false

# ── Security ──────────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change-me-before-use

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
